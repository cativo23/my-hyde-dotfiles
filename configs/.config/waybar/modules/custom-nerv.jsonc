{
  "custom/nerv": {
    "exec": "echo '{\"text\":\"MAGI.SYS\",\"tooltip\":\"'$(hostname -s)' // KERN '$(uname -r | cut -d- -f1)' // NODE '$(ip -4 addr show wlo1 2>/dev/null | grep -oP \"(?<=inet )[0-9.]+\" | head -1)'\"}'",
    "return-type": "json",
    "format": "{}",
    "tooltip": true,
    "interval": "once"
  }
}
