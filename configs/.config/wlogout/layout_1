{
    "label": "lock",
    "action": "hyde-shell lockscreen",
    "text": "SEC.LOCK",
    "keybind": "l"
}

{
    "label": "logout",
    "action": "hyde-shell logout",
    "text": "SYS.EXIT",
    "keybind": "e"
}

{
    "label": "suspend",
    "action": "hyde-shell lockscreen & disown && systemctl suspend",
    "text": "SYS.SLEEP",
    "keybind": "u"
}

{
    "label": "shutdown",
    "action": "systemctl poweroff",
    "text": "SYS.HALT",
    "keybind": "s"
}

{
    "label": "hibernate",
    "action": "systemctl hibernate",
    "text": "SYS.HBNT",
    "keybind": "h"
}

{
    "label": "reboot",
    "action": "systemctl reboot",
    "text": "SYS.BOOT",
    "keybind": "r"
}
