# Defaults
Host *
    AddKeysToAgent yes
    IdentitiesOnly yes
    ServerAliveInterval 60
    ServerAliveCountMax 3

# GitHub personal (default)
Host github.com gh-personal
    HostName ssh.github.com
    Port 443
    User git
    IdentityFile ~/.ssh/id_ed25519_personal

# GitHub work
Host gh-work
    HostName ssh.github.com
    Port 443
    User git
    IdentityFile ~/.ssh/id_ed25519_work

# Bitbucket personal
Host bitbucket bb-personal
    HostName bitbucket.org
    User git
    IdentityFile ~/.ssh/id_ed25519_personal

# Bitbucket work
Host bb-work
    HostName bitbucket.org
    User git
    IdentityFile ~/.ssh/id_ed25519_work

# Servers (siempre personal)
Host polaris cativo.dev
    Port 52222
    User cativo23
    IdentityFile ~/.ssh/id_ed25519_personal
